{
  "name": "@purdia/theme",
  "version": "0.1.0",
  "description": "Theme store — dark/light toggle + primary color switching with per-user persistence",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/purdia-theme.umd.cjs",
  "module": "./dist/purdia-theme.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/purdia-theme.js",
      "require": "./dist/purdia-theme.umd.cjs"
    }
  },
  "scripts": {
    "build": "vite build && tsc --declaration --emitDeclarationOnly --outDir dist",
    "dev": "vite build --watch"
  },
  "devDependencies": {
    "pinia": "^3.0.4",
    "typescript": "~6.0.0",
    "vite": "^8.0.16",
    "vue": "^3.5.38"
  },
  "peerDependencies": {
    "pinia": "^3.0.0",
    "vue": "^3.5.0"
  }
}
