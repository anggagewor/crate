{
  "name": "@purdia/composables",
  "version": "0.1.0",
  "description": "Reusable Vue composables — useApi, usePagination, and more",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/purdia-composables.umd.cjs",
  "module": "./dist/purdia-composables.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/purdia-composables.js",
      "require": "./dist/purdia-composables.umd.cjs"
    }
  },
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly --outDir dist",
    "dev": "vite build --watch"
  },
  "dependencies": {
    "@purdia/http": "^0.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "typescript": "~6.0.0",
    "vite": "^8.0.16",
    "vue": "^3.5.38",
    "vue-tsc": "^3.3.5"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  }
}
