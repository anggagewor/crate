{
  "name": "@purdia/toast",
  "version": "0.1.0",
  "description": "Toast notification system — Pinia store + Vue component + composable",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/purdia-toast.umd.cjs",
  "module": "./dist/purdia-toast.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/purdia-toast.js",
      "require": "./dist/purdia-toast.umd.cjs"
    }
  },
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly --outDir dist",
    "dev": "vite build --watch"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "pinia": "^3.0.4",
    "typescript": "~6.0.0",
    "vite": "^8.0.16",
    "vue": "^3.5.38",
    "vue-tsc": "^3.3.5"
  },
  "peerDependencies": {
    "@lucide/vue": "^1.0.0",
    "pinia": "^3.0.0",
    "vue": "^3.5.0"
  }
}
